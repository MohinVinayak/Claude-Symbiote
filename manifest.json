{
  "manifest_version": 3,
  "name": "Symbiote — Claude Monitor",
  "version": "1.0.0",
  "description": "Streams Claude.ai generation state to the Symbiote desktop overlay.",
  "permissions": [
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://*.claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
