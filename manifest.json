{
  "manifest_version": 3,
  "name": "Symbiote — Claude Monitor",
  "version": "1.0.0",
  "description": "Shows live Claude.ai generation status in a sleek floating pill overlay.",
  "permissions": [
    "tabs",
    "alarms",
    "storage"
  ],
  "action": {},
  "host_permissions": [
    "*://*.claude.ai/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.claude.ai/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["global_ui.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
